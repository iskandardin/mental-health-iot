# Environment variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_ADMIN_SDK_PATH=./firebase-admin-key.json

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRE=7d

# MQTT Configuration
MQTT_BROKER=mqtt://localhost
MQTT_PORT=1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password
MQTT_TOPIC_SENSOR=mindwear/sensors/data
MQTT_TOPIC_ALERT=mindwear/alerts

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@mindwear.com

# API Configuration
API_BASE_URL=http://localhost:5000
MOBILE_APP_URL=exp://localhost:19000

# Stress Analysis Thresholds
STRESS_ALERT_THRESHOLD=70
STRESS_CRITICAL_THRESHOLD=85
ANOMALY_DETECTION_ENABLED=true

# Alert Configuration
ALERT_EMAIL_ENABLED=true
ALERT_SMS_ENABLED=false
ALERT_PUSH_ENABLED=true

# Data Retention (days)
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
